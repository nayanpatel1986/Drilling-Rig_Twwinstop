# DrillBit Digital Twin - Environment Configuration Template
# COPY THIS TO .env AND UPDATE YOUR SECRETS

# --- InfluxDB ---
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=your-influx-token-here
INFLUXDB_ORG=nov_rig
INFLUXDB_BUCKET=rig_data
INFLUXDB_PASSWORD=password123

# --- Postgres ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
POSTGRES_DB=rig_manager

# --- MQTT (Mosquitto) ---
MQTT_USER=drillbit
MQTT_PASSWORD=password123
MQTT_HOST=mosquitto
MQTT_PORT=1883

# --- Backend Security ---
JWT_SECRET=generate-a-long-random-string-here
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:3001,http://127.0.0.1:3001

# --- Operational ---
LIVE_MODE=true
TELEGRAF_CONF_PATH=/telegraf-config/telegraf.conf
MANAGER_PIN=change-this-manager-pin
